{
  "name": "Ninj-OS Proxie Edge Fabric",
  "version": "7.3.6",
  "platform": "linux-x86_64; Windows 11 host through WSL2",
  "mode": "universal-dual-mode",
  "configuration": {
    "canonicalFile": "config/edge-fabric.ini",
    "exampleFile": "edge-fabric.example.ini",
    "secretReferenceSyntax": "env:VARIABLE_NAME or dashboard-managed raw value",
    "legacyMigration": "routes.conf"
  },
  "network": {
    "kingdom": "185.83.152.144:25566/UDP -> 185.83.152.144:25565",
    "zoo": "185.83.152.144:25571/UDP -> 185.83.152.144:19431",
    "dashboard": "185.83.152.144:25571/TCP",
    "transferPool": "185.83.152.144:25572-25581/UDP"
  },
  "management": {
    "backendCrud": true,
    "allocationValidation": true,
    "unifiedConfigEditor": true,
    "secretSourceStatus": true,
    "topologyRestart": true,
    "structuredSettingsEditor": true,
    "secretVault": true,
    "unifiedCredentialEditor": true,
    "minimumSecretLength": 12,
    "oneTimeSecretGeneration": true,
    "companionPropertiesDownload": true,
    "companionSourceDownload": true,
    "companionArtifactUpload": true,
    "companionInstallPackageDownload": true,
    "firstRunOwnerSetup": true,
    "passwordOwnerLogin": true,
    "ownerCredentialRotation": true,
    "singleUseSetupCode": true,
    "perBackendConnectionModes": true,
    "signedIdentityGrants": true,
    "universalBackendAdapters": true,
    "fullProxyPlayerRegistry": true,
    "networkRoleProfiles": true
  },
  "database": {
    "engine": "SQLite",
    "journalMode": "WAL",
    "path": "runtime/edge-fabric.db"
  },
  "features": [
    "transparent-microsoft-identity",
    "dashboard-backend-crud",
    "canonical-unified-configuration",
    "environment-secret-references",
    "legacy-route-migration",
    "destination-protection-profiles",
    "automatic-incident-mode",
    "adaptive-risk-firewall",
    "persistent-progressive-bans",
    "signed-transfer-transactions",
    "xuid-network-profiles",
    "automated-health-actions",
    "dashboard-sessions-and-optional-totp",
    "historical-metrics",
    "protocol-weave-packs",
    "tiered-packet-inspection",
    "decoded-packet-redaction",
    "selected-wire-sampling",
    "decode-round-trip-analysis",
    "redacted-support-bundles",
    "structured-dashboard-settings",
    "dashboard-secret-vault",
    "one-time-secret-generation",
    "companion-config-downloads",
    "companion-artifact-upload",
    "companion-install-package-builder",
    "shared-static-and-transfer-port-pool",
    "dynamic-unassigned-transfer-ports",
    "standalone-linux-installer",
    "systemd-service",
    "linux-docker-compose",
    "first-run-owner-setup",
    "password-owner-login",
    "single-use-setup-code",
    "dashboard-owner-account-management",
    "owner-managed-dashboard-subaccounts",
    "role-aware-dashboard-navigation",
    "emergency-recovery-session",
    "windows-wsl2-installer",
    "wsl2-mirrored-networking",
    "windows-firewall-automation",
    "hyper-v-firewall-automation",
    "windows-startup-task",
    "github-release-automation",
    "configuration-revision-verification",
    "companion-secret-fingerprints",
    "companion-signed-connectivity-probe",
    "companion-connection-diagnostics",
    "generated-companion-operator-guide",
    "companion-build-howto-artifact",
    "multi-server-companion-installation-guide",
    "transparent-auth-mode",
    "full-proxy-bedrock-session-core",
    "per-backend-authentication-mode",
    "signed-one-use-identity-grants",
    "endstone-identity-permission-bridge",
    "vanilla-script-api-bridge",
    "linux-vanilla-host-agent",
    "windows-vanilla-host-agent",
    "proxy-command-interception",
    "full-proxy-fallback-listeners",
    "operator-sync-by-verified-xuid",
    "native-online-mode-true-compatibility",
    "pinned-bedrock-protocol-runtime",
    "offline-complete-session-core-dependencies",
    "portable-nodejs-runtime-installer"
  ],
  "companion": {
    "version": "3.6.0-source",
    "defaultEndstoneTarget": "0.11.6",
    "buildTarget": "Ubuntu 22.04, glibc 2.35 or older"
  },
  "fixes": [
    "upstream-reference-acknowledgement",
    "runtime-facing-product-identity",
    "atomic-runtime-installer",
    "archive-checksum-validation",
    "version-aware-runtime-extraction",
    "dashboard-login-input-persistence",
    "startup-splash-restored",
    "first-run-owner-claim",
    "dashboard-password-login",
    "owner-password-recovery",
    "configuration-save-lock-inversion",
    "empty-environment-secret-rejection",
    "companion-server-id-normalization",
    "companion-dashboard-port-fallback",
    "ninj-os-console-banner-spelling",
    "companion-guide-release-generation"
  ],
  "engine": {
    "name": "Ninj-OS Edge Datagram Engine",
    "implementation": "Ninj-OS protocol-agnostic transport core",
    "transport": "transparent UDP shield plus protocol-aware Bedrock session proxy",
    "dependencies": [
      "Linux sockets",
      "epoll",
      "SQLite",
      "Go standard library",
      "Node.js 22",
      "bedrock-protocol 3.57.0"
    ]
  },
  "provenance": {
    "referenceProject": "ProxyPass",
    "referenceMaintainer": "SculkCatalystMC",
    "referenceUrl": "https://github.com/SculkCatalystMC/ProxyPass",
    "relationship": "developed with reference to and inspired by",
    "officialFork": false,
    "endorsedByUpstream": false
  },
  "deployment": {
    "pterodactyl": true,
    "linuxSystemd": true,
    "windowsWsl2": true,
    "linuxDocker": true,
    "nativeWindowsBinary": false,
    "vanillaBridgeBehaviorPack": true,
    "linuxVanillaAgent": true,
    "windowsVanillaAgent": true,
    "endstoneBridgeSource": true
  }
}
